{
  "catalogId": "edito-contribution",
  "packageName": "add-your-process",
  "packageVersion": "2.0.0",
  "name": "add-your-process",
  "friendlyName": "add-toolbox-catalogue-check",
  "share": false,
  "options": {
    "configuration": {
      "gpu": {
        "enabled": false
      },
      "containerImage": {
        "imageIsBuilt": false,
        "tag": "",
        "path": "src/Dockerfile"
      },
      "python": {
        "entrypointPath": "",
        "environmentPath": ""
      }
    },
    "metadata": {
      // "id": "test-renaud-deploy", Set in the code
      // "version": "0.0.5", Set as argument of the command
      "description": "",
      "icon": "",
      "home": "",
      "keywords": [],
      "appVersion": ""
    },
    "git": {
      "enabled": true,
      "name": "vgaubin",
      "email": "",
      "cache": "0",
      "token": "",
      "repository": "https://github.com/gkoenig-mercator/Automation-test-Marine-Data-Store",
      // "branch": "main" # Set as argument of the command
    },
    "copernicusMarine": {
      "enabled": false
    },
    "processInputs": [
      {
        name: 'DATABASE_URL',
        description: 'Full URL to connect to the database',
        defaultValue: '',
        required: true,
        type: 'string'
      },
      {
        name: 'COPERNICUSMARINE_SERVICE_USERNAME',
        description: 'Username for Copernicus Marine API',
        defaultValue: '',
        required: true,
        type: 'string'
      },
      {
        name: 'COPERNICUSMARINE_SERVICE_PASSWORD',
        description: 'Password for Copernicus Marine API',
        defaultValue: '',
        required: true,
        type: 'string'
      },
      {
        name: "REPORT_RECEIVER_EMAIL",
        description: "Email address to receive the csv reports.",
        defaultValue: "",
        required: false,
        type: "string"
      },
      {
        name: "REPORT_SENDER_EMAIL_PASSWORD",
        description: "Password for the email account used to send reports.",
        defaultValue: "",
        required: false,
        type: "string"
      },
    ],
    "resources": {
      "requests": {
        "cpu": "100m",
        "memory": "1Gi"
      },
      "limits": {
        "cpu": "1000m",
        "memory": "4Gi"
      }
    },
    "catalogType": "Process"
  },
  "dryRun": false
}