{
    "metadata": {
        "project": "test-datasets-subsetting-toolbox" // "project-" is added by the API
    },
    "processInputs": {
        "onyxia": {
            "friendlyName": "run-catalogue-check",
            "share": false
        },
        "resources": {
            "limits": {
                "cpu": "500m",
                "memory": "1Gi"
            },
            "requests": {
                "cpu": "100m",
                "memory": "200m"
            }
        },
        "vault": {
            "enabled": true,
            // token": "", // Set as environment variable in the workflow
            "url": "https://vault.dive.edito.eu",
            "mount": "secret-kv",
            "directory": "project-test-datasets-subsetting-toolbox",
            "secret": "cataloguechecks"
        },
        "s3": {
            "enabled": true,
            "accessKeyId": "",
            "endpoint": "minio.dive.edito.eu",
            "bucketName": "",
            "defaultRegion": "waw3-1",
            "secretAccessKey": "",
            "sessionToken": ""
        },
        "inputs": {
            // "DATABASE_URL": "postgresql://postgres: Set in the code
        }
    }
}